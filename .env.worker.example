DATABASE_URL=${{Postgres.DATABASE_URL}}
REDIS_URL=redis://REPLACE_WITH_REDIS_HOST:6379
QUORUM_API_BASE_URL=https://<api-public-domain>/api/v1
QUORUM_AUTH_FRONTEND_BASE_URL=https://<frontend-public-domain>
QUORUM_BASE_URL=https://<frontend-public-domain>
QUORUM_EMAIL_FROM=alerts@your-domain.com
TELEGRAM_BOT_TOKEN=REPLACE_WITH_TELEGRAM_BOT_TOKEN
QUORUM_TELEGRAM_BOT_USERNAME=QuorumSignalsBot
QUORUM_TELEGRAM_CONNECT_CODE_TTL_MINUTES=15
QUORUM_TELEGRAM_POLL_INTERVAL_MS=15000
RESEND_API_KEY=REPLACE_WITH_RESEND_API_KEY
SMART_MONEY_SCHEDULER_ENABLED=true
SMART_MONEY_REFRESH_INTERVAL_MS=900000
SMART_MONEY_SNAPSHOT_REFRESH_INTERVAL_MS=1800000
SMART_MONEY_DISCOVERY_LOOKBACK_DAYS=30
SMART_MONEY_DISCOVERY_WALLET_LIMIT=40
SMART_MONEY_LEADERBOARD_LIMIT=20
SMART_MONEY_WATCH_WALLET_LIMIT=100
SMART_MONEY_ACTIVITY_LOOKBACK_DAYS=7
SMART_MONEY_MIN_SIGNAL_SIZE_USD=500
